# ============================================================
# MORIA — Variáveis de Ambiente
# Copie este arquivo para .env.local e preencha os valores.
# Para desenvolvimento local: npm run setup (após npm run db:start)
# Para produção: use as chaves do seu projeto Supabase em nuvem.
# ============================================================

# Supabase — obtenha em: Settings → API no dashboard do Supabase
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL pública do app (usado em redirects de auth)
NEXT_PUBLIC_APP_URL=http://localhost:3000
